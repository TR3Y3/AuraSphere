# Database
DATABASE_URL=postgresql://user:password@localhost/aurasphere

# Auth / session
SESSION_SECRET=your-secret-key-here-change-in-production
SESSION_COOKIE_NAME=aurasphere_session
SESSION_TTL_HOURS=168
# Set true in production (HTTPS). Leave false for local http.
COOKIE_SECURE=false
# Cookie SameSite: "lax" for local dev; "none" when the SPA and API are on
# different sites (e.g. *.onrender.com) — "none" forces Secure on.
COOKIE_SAMESITE=lax
# Optional parent domain so app.<domain> and api.<domain> share the cookie.
# COOKIE_DOMAIN=.example.com

# CORS: exact SPA origin (credentials are enabled)
FRONTEND_ORIGIN=http://localhost:5173

# Email delivery for signup verification.
#   console (default) — logs the message; signup returns the verify link so it
#                       works without a mailbox. Fine for local dev.
#   resend            — Resend HTTP API; set RESEND_API_KEY. Use in production
#                       (works on Render, which blocks outbound SMTP ports).
#   smtp              — classic SMTP; set SMTP_HOST/PORT/USER/PASSWORD.
EMAIL_DELIVERY=console
EMAIL_FROM=no-reply@aurasphere.app
# RESEND_API_KEY=re_...
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# How long an email-verification link stays valid (hours).
VERIFY_TTL_HOURS=48

# Billing / plan-gating.
#   stub (default) — no Stripe; "upgrade" instantly flips the org to Pro so the
#                    upgrade→unlock loop is fully testable. Use for dev/demo.
#   stripe         — real Checkout + Billing Portal + webhooks via the Stripe
#                    REST API; set the keys below and point a webhook at
#                    /api/billing/webhook.
BILLING_MODE=stub
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...        # the recurring Pro price
# STRIPE_WEBHOOK_SECRET=whsec_...
# Free-plan load ceiling (Pro is unlimited).
FREE_MAX_LOADS=50

# Seed commands (python -m app.seed all)
SEED_ORG_NAME=AuraSphere
SEED_ORG_SLUG=aurasphere
# Per-tenant brand accent (hex), e.g. #1f9e5e. Optional; falls back to violet.
SEED_ORG_ACCENT=
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-please
SEED_ADMIN_NAME=Admin
