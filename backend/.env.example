# Database
DATABASE_URL=postgresql://user:password@localhost/aurasphere

# Auth / session
SESSION_SECRET=your-secret-key-here-change-in-production
SESSION_COOKIE_NAME=aurasphere_session
SESSION_TTL_HOURS=168
# Set true in production (HTTPS). Leave false for local http.
COOKIE_SECURE=false
# Optional parent domain so app.<domain> and api.<domain> share the cookie.
# COOKIE_DOMAIN=.example.com

# CORS: exact SPA origin (credentials are enabled)
FRONTEND_ORIGIN=http://localhost:5173

# Seed commands (python -m app.seed all)
SEED_ORG_NAME=AuraSphere
SEED_ORG_SLUG=aurasphere
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-please
SEED_ADMIN_NAME=Admin
